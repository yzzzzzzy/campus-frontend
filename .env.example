# Backend server port
PORT=3000

# Public URL of backend service for file links (set your cloud domain/IP in production)
# Example: https://api.your-domain.com
SERVER_PUBLIC_BASE_URL=http://localhost:3000

# Database config
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=campus_info_db

# JWT secret
JWT_SECRET=replace_with_a_secure_random_string
